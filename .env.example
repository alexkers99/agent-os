# ── Hermes (OpenAI-compatible) ────────────────────────────────────────────────
# Your Hostinger VPS endpoint. Must speak POST /v1/chat/completions.
HERMES_BASE_URL=https://your-vps-domain.com/v1
HERMES_API_KEY=sk-xxxxx            # leave blank if your endpoint is unauthenticated
HERMES_MODEL=hermes               # the model name your endpoint expects, passed through as-is

# ── Telegram bridge ───────────────────────────────────────────────────────────
# Shared secret your existing bot includes when it POSTs to /api/telegram.
# Generate one: `openssl rand -hex 24`
TELEGRAM_BRIDGE_SECRET=change-me

# ── Tools ─────────────────────────────────────────────────────────────────────
# Agents can read/write files only inside this dir, and run shell only here.
AGENT_WORKSPACE_DIR=./workspace
# Master switch for the run_shell tool. Off by default — turn on deliberately.
ALLOW_SHELL=false

# ── Loop limits ───────────────────────────────────────────────────────────────
MAX_LOOP_ITERATIONS=8
